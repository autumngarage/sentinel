{
  "name": "sentinel",
  "version": "0.1.0",
  "description": "Autonomous meta-agent that manages software projects through a continuous loop of goal-setting, state assessment, research, planning, and delegated execution across multiple LLM providers.",
  "type": "module",
  "bin": {
    "sentinel": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "validate": "pnpm typecheck && pnpm lint && pnpm test"
  },
  "keywords": [
    "ai",
    "agent",
    "meta-agent",
    "llm",
    "project-management",
    "autonomous",
    "claude",
    "openai",
    "gemini",
    "ollama"
  ],
  "author": "Henry Modisett",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "openai": "^6.18.0",
    "@google/genai": "^1.49.0",
    "commander": "^13.0.0",
    "inquirer": "^12.0.0",
    "chalk": "^5.4.0",
    "toml": "^3.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  }
}
